# Groq API Key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cognitia?retryWrites=true&w=majority

# Your deployed frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Port (Vercel sets this automatically; only needed for local dev)
PORT=5000
